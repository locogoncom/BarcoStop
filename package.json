{
  "name": "barcostop",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "test": "npm run test:api && npm run test:mobile",
    "test:api": "npm run test:api:legacy && npm run test:api:phpunit",
    "test:api:legacy": "php tests/api/php/run.php",
    "test:api:phpunit": "composer --working-dir api test",
    "test:api:live:prod": "BARCOSTOP_RUN_LIVE_AUTH_TEST=1 BARCOSTOP_RUN_LIVE_TRIP_CRUD_TEST=1 BARCOSTOP_RUN_LIVE_UPLOAD_TEST=1 BARCOSTOP_LIVE_API_BASE_URL=https://api.barcostop.net/api/v1 BARCOSTOP_TEST_EMAIL=betolopezayesa@gmail.com BARCOSTOP_TEST_PASSWORD=test22 composer --working-dir api test",
    "test:mobile": "npm --prefix mobile test -- --runInBand --testPathPattern=../tests/mobile",
    "start": "npm --prefix server start",
    "postinstall": "npm --prefix server install",
    "barcostop:activate": "powershell -ExecutionPolicy Bypass -File ./scripts/continuar-barcostop.ps1",
    "keep:continue": "powershell -ExecutionPolicy Bypass -File ./scripts/continuar-keep.ps1",
    "keeplay:continue": "npm run keep:continue",
    "app:barcostop": "powershell -ExecutionPolicy Bypass -File ./apps/BarcoStop/open.ps1",
    "app:keep": "powershell -ExecutionPolicy Bypass -File ./apps/Keep/open.ps1",
    "app:keeplay": "npm run app:keep",
    "app:keepplaying": "npm run app:keep",
    "keep:backend": "npm --prefix ./apps/Keep/server start",
    "keep:metro": "npm --prefix ./apps/Keep/mobile run dev:metro",
    "keep:activate": "npm --prefix ./apps/Keep/mobile run dev:activate",
    "keep:stable": "npm --prefix ./apps/Keep/mobile run dev:stable",
    "keep:launch": "npm --prefix ./apps/Keep/mobile run dev:launch"
  },
  "dependencies": {},
  "devDependencies": {
    "@resvg/resvg-js": "^2.6.2",
    "@types/react": "^18.2.37",
    "@types/react-dom": "^18.2.15",
    "@vitejs/plugin-react": "^4.1.0",
    "autoprefixer": "^10.4.16",
    "postcss": "^8.4.31",
    "tailwindcss": "^3.3.5",
    "typescript": "^5.2.2",
    "vite": "^4.4.5"
  }
}