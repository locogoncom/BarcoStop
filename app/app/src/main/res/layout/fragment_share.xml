<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bs_bg"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:id="@+id/share_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/share_title"
            android:textColor="@color/bs_text"
            android:textSize="24sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/share_subtitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/share_subtitle"
            android:textColor="@color/bs_text_muted"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/share_counter"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="@string/share_counter_template"
            android:textColor="@color/bs_primary"
            android:textSize="13sp"
            android:textStyle="bold" />

        <Button
            android:id="@+id/share_btn_campaign"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="@string/share_btn_campaign" />

        <Button
            android:id="@+id/share_btn_whatsapp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="@string/share_btn_whatsapp" />

        <Button
            android:id="@+id/share_btn_instagram"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="@string/share_btn_instagram" />

        <Button
            android:id="@+id/share_btn_qr"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="@string/share_btn_qr" />

        <Button
            android:id="@+id/share_btn_donate"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="@string/share_btn_donate" />
    </LinearLayout>

</ScrollView>
