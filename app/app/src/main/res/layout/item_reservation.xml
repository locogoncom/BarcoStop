<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    style="@style/Widget.BarcoStop.Card"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="10dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="14dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/res_title"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:ellipsize="end"
                android:maxLines="1"
                android:textColor="@color/bs_text"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/res_status"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:background="@drawable/bg_res_status_chip"
                android:paddingHorizontal="12dp"
                android:paddingVertical="5dp"
                android:textColor="@color/white"
                android:textSize="14sp"
                android:textStyle="bold" />
        </LinearLayout>

        <TextView
            android:id="@+id/res_subtitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:background="@drawable/bg_input"
            android:ellipsize="end"
            android:maxLines="4"
            android:paddingHorizontal="12dp"
            android:paddingVertical="10dp"
            android:textColor="@color/bs_text_muted"
            android:textSize="15sp" />

        <TextView
            android:id="@+id/res_feedback"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:background="#FDE9EC"
            android:gravity="center"
            android:paddingHorizontal="12dp"
            android:paddingVertical="10dp"
            android:textColor="#C61F35"
            android:textStyle="bold"
            android:visibility="gone" />

        <LinearLayout
            android:id="@+id/res_actions"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:orientation="horizontal">

            <Button
                android:id="@+id/res_action_primary"
                style="@style/Widget.BarcoStop.Button.Compact"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/common_action" />

            <Button
                android:id="@+id/res_action_secondary"
                style="@style/Widget.BarcoStop.Button.Compact.Danger"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:text="@string/common_action" />

            <Button
                android:id="@+id/res_action_tertiary"
                style="@style/Widget.BarcoStop.Button.Compact"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:text="@string/common_action"
                android:visibility="gone" />
        </LinearLayout>

        <TextView
            android:id="@+id/res_avatar"
            android:layout_width="1dp"
            android:layout_height="1dp"
            android:visibility="gone" />

        <View
            android:id="@+id/res_divider"
            android:layout_width="1dp"
            android:layout_height="1dp"
            android:visibility="gone" />
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
