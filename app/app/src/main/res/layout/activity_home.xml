<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_page"
    android:orientation="vertical">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="88dp"
        android:background="@color/bs_primary"
        android:gravity="center_vertical"
        android:paddingHorizontal="16dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/home_native_badge"
            android:textColor="@color/white"
            android:textSize="22sp"
            android:textStyle="bold" />
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:paddingHorizontal="14dp"
        android:paddingTop="14dp"
        android:paddingBottom="20dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <com.google.android.material.card.MaterialCardView
                style="@style/Widget.BarcoStop.Card"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="0dp"
                app:cardCornerRadius="24dp"
                xmlns:app="http://schemas.android.com/apk/res-auto">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="18dp">

                    <ImageView
                        android:layout_width="130dp"
                        android:layout_height="130dp"
                        android:layout_gravity="center_horizontal"
                        android:contentDescription="@string/app_name"
                        android:src="@drawable/ic_barcostop_logo" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:gravity="center"
                        android:text="@string/home_title"
                        android:textColor="@color/bs_primary_dark"
                        android:textSize="30sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:gravity="center"
                        android:text="@string/home_subtitle"
                        android:textColor="@color/bs_primary_dark"
                        android:textSize="14sp" />

                    <Button
                        android:id="@+id/btn_continue_session"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:text="@string/home_continue_session"
                        android:visibility="gone" />

                    <Button
                        android:id="@+id/btn_start_captain"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:text="@string/home_start_captain" />

                    <Button
                        android:id="@+id/btn_start_traveler"
                        style="@style/Widget.BarcoStop.Button.Secondary"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:text="@string/home_start_traveler" />

                    <Button
                        android:id="@+id/btn_logout"
                        style="@style/Widget.BarcoStop.Button.Secondary"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:text="@string/home_logout"
                        android:visibility="gone" />

                    <TextView
                        android:id="@+id/home_callout"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:gravity="center"
                        android:text="@string/home_callout"
                        android:textColor="@color/bs_primary_dark"
                        android:textSize="14sp"
                        android:textStyle="bold" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                style="@style/Widget.BarcoStop.Card"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                xmlns:app="http://schemas.android.com/apk/res-auto"
                app:cardCornerRadius="20dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="14dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:text="@string/language_title"
                        android:textColor="@color/bs_text"
                        android:textSize="18sp"
                        android:textStyle="bold" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:orientation="horizontal"
                        android:weightSum="4">

                        <Button
                            android:id="@+id/home_lang_en"
                            style="@style/Widget.BarcoStop.Button.Secondary"
                            android:layout_width="0dp"
                            android:layout_height="80dp"
                            android:layout_marginEnd="6dp"
                            android:layout_weight="1"
                            android:textColor="@color/white"
                            android:text="🇬🇧\nEN" />

                        <Button
                            android:id="@+id/home_lang_es"
                            style="@style/Widget.BarcoStop.Button.Secondary"
                            android:layout_width="0dp"
                            android:layout_height="80dp"
                            android:layout_marginEnd="6dp"
                            android:layout_weight="1"
                            android:textColor="@color/white"
                            android:text="🇪🇸\nES" />

                        <Button
                            android:id="@+id/home_lang_fr"
                            style="@style/Widget.BarcoStop.Button.Secondary"
                            android:layout_width="0dp"
                            android:layout_height="80dp"
                            android:layout_marginEnd="6dp"
                            android:layout_weight="1"
                            android:textColor="@color/white"
                            android:text="🇫🇷\nFR" />

                        <Button
                            android:id="@+id/home_lang_pt"
                            style="@style/Widget.BarcoStop.Button.Secondary"
                            android:layout_width="0dp"
                            android:layout_height="80dp"
                            android:layout_weight="1"
                            android:textColor="@color/white"
                            android:text="🇵🇹\nPT" />
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <TextView
                android:id="@+id/home_build_info"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:alpha="0.96"
                android:background="@drawable/bg_build_badge"
                android:maxLines="1"
                android:paddingHorizontal="6dp"
                android:paddingVertical="2dp"
                android:textColor="@color/white"
                android:textSize="10sp" />
        </LinearLayout>
    </ScrollView>

</LinearLayout>
