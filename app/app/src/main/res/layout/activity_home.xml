<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_page">

    <View
        android:layout_width="220dp"
        android:layout_height="220dp"
        android:layout_gravity="top|end"
        android:layout_marginTop="-56dp"
        android:layout_marginEnd="-36dp"
        android:background="@drawable/bg_input" />

    <View
        android:layout_width="250dp"
        android:layout_height="250dp"
        android:layout_gravity="bottom|start"
        android:layout_marginBottom="-86dp"
        android:layout_marginStart="-70dp"
        android:background="@drawable/bg_input" />

    <LinearLayout
        android:layout_gravity="center"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="20dp"
        android:background="@drawable/bg_home_card"
        android:elevation="3dp"
        android:orientation="vertical"
        android:padding="20dp">

        <ImageView
            android:layout_width="120dp"
            android:layout_height="120dp"
            android:layout_gravity="center_horizontal"
            android:contentDescription="@string/app_name"
            android:src="@drawable/ic_barcostop_logo" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:text="@string/home_title"
            android:textColor="@color/bs_primary_dark"
            android:textSize="32sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="8dp"
            android:gravity="center"
            android:text="@string/home_subtitle"
            android:textColor="@color/bs_text_muted"
            android:textSize="14sp" />

        <Button
            android:id="@+id/btn_continue_session"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="@string/home_continue_session"
            android:visibility="gone" />

        <Button
            android:id="@+id/btn_start_captain"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="@string/home_start_captain" />

        <Button
            android:id="@+id/btn_start_traveler"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="@string/home_start_traveler" />

        <Button
            android:id="@+id/btn_logout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="@string/home_logout"
            android:visibility="gone" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|center_horizontal"
        android:layout_marginHorizontal="20dp"
        android:layout_marginBottom="36dp"
        android:background="@drawable/bg_home_card"
        android:orientation="vertical"
        android:padding="10dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:text="@string/language_title"
            android:textColor="@color/bs_text_muted"
            android:textSize="12sp"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:gravity="center"
            android:orientation="horizontal">

            <Button
                android:id="@+id/home_lang_en"
                style="@style/Widget.BarcoStop.Button.Secondary"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginEnd="6dp"
                android:layout_weight="1"
                android:minHeight="42dp"
                android:text="🇬🇧 EN"
                android:textSize="11sp" />

            <Button
                android:id="@+id/home_lang_es"
                style="@style/Widget.BarcoStop.Button.Secondary"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginEnd="6dp"
                android:layout_weight="1"
                android:minHeight="42dp"
                android:text="🇪🇸 ES"
                android:textSize="11sp" />

            <Button
                android:id="@+id/home_lang_fr"
                style="@style/Widget.BarcoStop.Button.Secondary"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginEnd="6dp"
                android:layout_weight="1"
                android:minHeight="42dp"
                android:text="🇫🇷 FR"
                android:textSize="11sp" />

            <Button
                android:id="@+id/home_lang_pt"
                style="@style/Widget.BarcoStop.Button.Secondary"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:minHeight="42dp"
                android:text="🇵🇹 PT"
                android:textSize="11sp" />
        </LinearLayout>
    </LinearLayout>

    <TextView
        android:id="@+id/home_build_info"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|start"
        android:layout_marginStart="10dp"
        android:layout_marginBottom="8dp"
        android:alpha="0.92"
        android:background="@drawable/bg_input"
        android:elevation="6dp"
        android:maxLines="1"
        android:ellipsize="end"
        android:paddingHorizontal="6dp"
        android:paddingVertical="2dp"
        android:textColor="@color/bs_primary_dark"
        android:textSize="10sp" />

</FrameLayout>
