<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    style="@style/Widget.BarcoStop.Card"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="8dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="12dp">

        <TextView
            android:id="@+id/user_browse_name"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/bs_primary_dark"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/user_browse_role"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:textColor="@color/bs_text"
            android:textSize="13sp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:orientation="horizontal">

            <Button
                android:id="@+id/user_browse_profile"
                style="@style/Widget.BarcoStop.Button.Secondary"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/users_profile" />

            <Button
                android:id="@+id/user_browse_chat"
                style="@style/Widget.BarcoStop.Button.Secondary"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="6dp"
                android:layout_weight="1"
                android:text="@string/users_chat" />

            <Button
                android:id="@+id/user_browse_favorite"
                style="@style/Widget.BarcoStop.Button"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="6dp"
                android:layout_weight="1"
                android:text="@string/users_favorite_add" />
        </LinearLayout>
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
