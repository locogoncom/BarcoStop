<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_page"
    android:orientation="vertical">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/edit_toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/bs_primary_dark"
        android:elevation="2dp"
        android:theme="@style/ThemeOverlay.Material3.Dark.ActionBar"
        app:navigationIconTint="@color/white"
        app:title="@string/trip_btn_edit"
        app:titleTextColor="@color/white" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="12dp"
            android:background="@drawable/bg_section_card"
            android:orientation="vertical"
            android:padding="16dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/trip_form_type"
            android:textColor="@color/bs_primary_dark"
            android:textStyle="bold" />

        <RadioGroup
            android:id="@+id/edit_trip_kind"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:orientation="horizontal">

            <RadioButton
                android:id="@+id/edit_kind_trip"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:checked="true"
                android:text="@string/trip_form_type_trip" />

            <RadioButton
                android:id="@+id/edit_kind_regatta"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:text="@string/trip_form_type_regatta" />
        </RadioGroup>

        <EditText
            android:id="@+id/edit_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:hint="@string/trip_form_title_hint" />

        <EditText
            android:id="@+id/edit_note"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:gravity="top"
            android:hint="@string/trip_form_note_hint"
            android:inputType="textMultiLine"
            android:minLines="3" />

        <EditText
            android:id="@+id/edit_boat_image_url"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:hint="@string/trip_form_boat_image_hint" />

        <EditText
            android:id="@+id/edit_origin"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:hint="@string/trip_form_origin_hint" />

        <EditText
            android:id="@+id/edit_destination"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:hint="@string/trip_form_destination_hint" />

        <EditText
            android:id="@+id/edit_date"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:hint="@string/trip_form_date_hint" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="@string/trip_form_time_window"
            android:textColor="@color/bs_primary_dark"
            android:textStyle="bold" />

        <RadioGroup
            android:id="@+id/edit_time_window"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:orientation="horizontal">

            <RadioButton
                android:id="@+id/edit_time_morning"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:checked="true"
                android:text="@string/trip_form_time_morning" />

            <RadioButton
                android:id="@+id/edit_time_afternoon"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="10dp"
                android:text="@string/trip_form_time_afternoon" />

            <RadioButton
                android:id="@+id/edit_time_night"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="10dp"
                android:text="@string/trip_form_time_night" />
        </RadioGroup>

        <EditText
            android:id="@+id/edit_seats"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:hint="@string/trip_form_seats_hint"
            android:inputType="number" />

        <EditText
            android:id="@+id/edit_price"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:hint="@string/trip_form_price_hint"
            android:inputType="numberDecimal" />

        <EditText
            android:id="@+id/edit_contribution_type"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:hint="@string/trip_form_contribution_type_hint"
            android:visibility="gone" />

        <EditText
            android:id="@+id/edit_contribution_note"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:gravity="top"
            android:hint="@string/trip_form_contribution_note_hint"
            android:inputType="textMultiLine"
            android:minLines="2"
            android:visibility="gone" />

        <Button
            android:id="@+id/edit_submit"
            style="@style/Widget.BarcoStop.Button"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:text="@string/trip_form_edit_submit" />

        <ProgressBar
            android:id="@+id/edit_loading"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="14dp"
            android:visibility="gone" />
        </LinearLayout>
    </ScrollView>
</LinearLayout>
