<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_page">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="12dp"
        android:layout_marginTop="12dp"
        android:layout_marginBottom="20dp"
        android:background="@drawable/bg_section_card"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:id="@+id/detail_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/bs_primary_dark"
            android:textSize="22sp"
            android:textStyle="bold" />

        <ImageView
            android:id="@+id/detail_image"
            android:layout_width="match_parent"
            android:layout_height="210dp"
            android:layout_marginTop="10dp"
            android:background="@drawable/bg_input"
            android:contentDescription="@string/app_name"
            android:scaleType="centerCrop"
            android:visibility="gone" />

        <TextView
            android:id="@+id/detail_route"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:textColor="@color/bs_text_muted" />

        <TextView
            android:id="@+id/detail_meta"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:textColor="@color/bs_text_muted" />

        <TextView
            android:id="@+id/detail_note"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:textColor="@color/bs_text"
            android:visibility="gone" />

        <TextView
            android:id="@+id/detail_status"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:paddingHorizontal="8dp"
            android:paddingVertical="3dp"
            android:textColor="@color/white" />

        <Button
            android:id="@+id/detail_reserve"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:text="@string/trip_btn_reserve" />

        <Button
            android:id="@+id/detail_cancel_reservation"
            style="@style/Widget.BarcoStop.Button.Danger"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="@string/trip_btn_cancel_reservation"
            android:visibility="gone" />

        <Button
            android:id="@+id/detail_chat"
            style="@style/Widget.BarcoStop.Button.Secondary"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="@string/trip_btn_chat" />

        <Button
            android:id="@+id/detail_view_profile"
            style="@style/Widget.BarcoStop.Button.Secondary"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="@string/trip_view_captain_profile" />

        <Button
            android:id="@+id/detail_favorite_toggle"
            style="@style/Widget.BarcoStop.Button.Secondary"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="@string/trip_btn_favorite_add"
            android:visibility="gone" />

        <Button
            android:id="@+id/detail_edit_trip"
            style="@style/Widget.BarcoStop.Button.Secondary"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="@string/trip_btn_edit"
            android:visibility="gone" />

        <Button
            android:id="@+id/detail_cancel_trip"
            style="@style/Widget.BarcoStop.Button.Secondary"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="@string/trip_btn_cancel_trip"
            android:visibility="gone" />

        <Button
            android:id="@+id/detail_delete_trip"
            style="@style/Widget.BarcoStop.Button.Danger"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="@string/trip_btn_delete"
            android:visibility="gone" />

        <Button
            android:id="@+id/detail_reddit_autopublish"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="@string/trip_reddit_autopublish"
            android:visibility="gone" />

        <ProgressBar
            android:id="@+id/detail_loading"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="16dp" />
    </LinearLayout>
</ScrollView>
