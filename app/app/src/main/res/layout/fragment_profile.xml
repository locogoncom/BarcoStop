<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_page">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="12dp"
        android:background="@drawable/bg_section_card"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:id="@+id/profile_email"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/bs_text"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/profile_role"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:textColor="@color/bs_text_muted"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/profile_optional_note"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="@string/profile_optional_note"
            android:textColor="@color/bs_text_muted"
            android:textSize="12sp" />

        <TextView
            android:id="@+id/profile_avatar_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:text="@string/profile_avatar_title"
            android:textColor="@color/bs_primary_dark"
            android:textStyle="bold" />

        <ImageView
            android:id="@+id/profile_avatar_preview"
            android:layout_width="88dp"
            android:layout_height="88dp"
            android:layout_marginTop="8dp"
            android:background="@drawable/bg_input"
            android:padding="6dp"
            android:scaleType="centerCrop"
            android:src="@drawable/ic_barcostop_logo" />

        <TextView
            android:id="@+id/profile_avatar_hint"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="@string/profile_avatar_none"
            android:textColor="@color/bs_text_muted"
            android:textSize="12sp" />

        <Button
            android:id="@+id/profile_avatar_pick"
            style="@style/Widget.BarcoStop.Button.Secondary"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/profile_avatar_pick" />

        <EditText
            android:id="@+id/profile_name_input"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:hint="@string/profile_name" />

        <EditText
            android:id="@+id/profile_bio_input"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:hint="@string/profile_bio"
            android:inputType="textMultiLine"
            android:maxLines="5"
            android:minLines="3" />

        <EditText
            android:id="@+id/profile_current_location_input"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:hint="@string/profile_current_location" />

        <EditText
            android:id="@+id/profile_instagram_input"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:hint="@string/profile_instagram" />

        <EditText
            android:id="@+id/profile_phone_input"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:hint="@string/profile_phone"
            android:inputType="phone" />

        <EditText
            android:id="@+id/profile_languages_input"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:hint="@string/profile_languages" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="16dp"
            android:background="@color/bs_border" />

        <TextView
            android:id="@+id/profile_traveler_section_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="@string/profile_traveler_section"
            android:textColor="@color/bs_primary_dark"
            android:textSize="14sp"
            android:textStyle="bold" />

        <EditText
            android:id="@+id/profile_sailing_experience_input"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:hint="@string/profile_sailing_experience" />

        <EditText
            android:id="@+id/profile_certifications_input"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:hint="@string/profile_certifications" />

        <EditText
            android:id="@+id/profile_preferred_routes_input"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:hint="@string/profile_preferred_routes" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="16dp"
            android:background="@color/bs_border" />

        <TextView
            android:id="@+id/profile_captain_section_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="@string/profile_captain_section"
            android:textColor="@color/bs_primary_dark"
            android:textSize="14sp"
            android:textStyle="bold" />

        <EditText
            android:id="@+id/profile_boat_name_input"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:hint="@string/profile_boat_name" />

        <EditText
            android:id="@+id/profile_boat_type_input"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:hint="@string/profile_boat_type" />

        <EditText
            android:id="@+id/profile_boat_model_input"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:hint="@string/profile_boat_model" />

        <EditText
            android:id="@+id/profile_boat_length_input"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:hint="@string/profile_boat_length"
            android:inputType="numberDecimal" />

        <EditText
            android:id="@+id/profile_home_port_input"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:hint="@string/profile_home_port" />

        <EditText
            android:id="@+id/profile_captain_license_input"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:hint="@string/profile_captain_license" />

        <EditText
            android:id="@+id/profile_boat_capacity_input"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:hint="@string/profile_boat_capacity"
            android:inputType="number" />

        <EditText
            android:id="@+id/profile_boat_year_input"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:hint="@string/profile_boat_year"
            android:inputType="number" />

        <EditText
            android:id="@+id/profile_boat_license_input"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:hint="@string/profile_boat_license" />

        <EditText
            android:id="@+id/profile_boat_photo_1_input"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:hint="@string/profile_boat_photo_1" />

        <EditText
            android:id="@+id/profile_boat_photo_2_input"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:hint="@string/profile_boat_photo_2" />

        <EditText
            android:id="@+id/profile_boat_photo_3_input"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:hint="@string/profile_boat_photo_3" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="18dp"
            android:background="@color/bs_border" />

        <TextView
            android:id="@+id/profile_my_trips_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="@string/profile_my_trips"
            android:textColor="@color/bs_primary_dark"
            android:textSize="15sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/profile_my_trips_empty"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/profile_my_trips_empty"
            android:textColor="@color/bs_text_muted"
            android:visibility="gone" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/profile_my_trips_recycler"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:nestedScrollingEnabled="false" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="18dp"
            android:background="@color/bs_border" />

        <TextView
            android:id="@+id/profile_reputation_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="@string/profile_reputation_title"
            android:textColor="@color/bs_primary_dark"
            android:textSize="15sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/profile_rating_summary"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/profile_rating_summary_placeholder"
            android:textColor="@color/bs_text" />

        <TextView
            android:id="@+id/profile_donation_summary"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="@string/profile_donation_summary_placeholder"
            android:textColor="@color/bs_text_muted" />

        <Button
            android:id="@+id/profile_donate_button"
            style="@style/Widget.BarcoStop.Button.Secondary"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="@string/profile_donate_cta" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="18dp"
            android:background="@color/bs_border" />

        <TextView
            android:id="@+id/profile_support_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="@string/profile_support_title"
            android:textColor="@color/bs_primary_dark"
            android:textSize="15sp"
            android:textStyle="bold" />

        <EditText
            android:id="@+id/profile_support_input"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:hint="@string/profile_support_hint"
            android:inputType="textMultiLine"
            android:maxLines="5"
            android:minLines="3" />

        <Button
            android:id="@+id/profile_support_send"
            style="@style/Widget.BarcoStop.Button.Secondary"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="@string/profile_support_send" />

        <TextView
            android:id="@+id/profile_support_empty"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/profile_support_empty"
            android:textColor="@color/bs_text_muted"
            android:visibility="gone" />

        <LinearLayout
            android:id="@+id/profile_support_list"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:orientation="vertical" />

        <LinearLayout
            android:id="@+id/profile_tools_row"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:orientation="horizontal">

            <Button
                android:id="@+id/profile_open_users"
                style="@style/Widget.BarcoStop.Button.Secondary"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/profile_open_users" />

            <Button
                android:id="@+id/profile_open_boats"
                style="@style/Widget.BarcoStop.Button.Secondary"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:layout_weight="1"
                android:text="@string/profile_open_boats" />
        </LinearLayout>

        <Button
            android:id="@+id/profile_save_button"
            style="@style/Widget.BarcoStop.Button"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:text="@string/profile_save" />

        <Button
            android:id="@+id/profile_logout_button"
            style="@style/Widget.BarcoStop.Button.Danger"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="@string/home_logout" />

        <ProgressBar
            android:id="@+id/profile_loading"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="16dp"
            android:visibility="gone" />
    </LinearLayout>
</ScrollView>
