<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_page"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center_vertical"
        android:orientation="vertical"
        android:paddingHorizontal="20dp"
        android:paddingTop="24dp"
        android:paddingBottom="20dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_home_card"
            android:gravity="center_horizontal"
            android:orientation="vertical"
            android:padding="18dp">

        <ImageView
            android:id="@+id/auth_logo"
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:src="@drawable/ic_barcostop_logo"
            android:contentDescription="@string/app_name" />

        <TextView
            android:id="@+id/tv_auth_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:gravity="center"
            android:text="@string/auth_login"
            android:textColor="@color/bs_primary_dark"
            android:textSize="24sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tv_auth_subtitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:gravity="center"
            android:text="@string/auth_subtitle"
            android:textColor="@color/bs_text_muted"
            android:textSize="13sp" />

        <TextView
            android:id="@+id/tv_auth_role"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:gravity="center"
            android:textColor="@color/bs_text"
            android:textSize="15sp" />

        <EditText
            android:id="@+id/et_name"
            style="@style/Widget.BarcoStop.EditText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:hint="@string/auth_name"
            android:inputType="textPersonName"
            android:visibility="gone" />

        <EditText
            android:id="@+id/et_email"
            style="@style/Widget.BarcoStop.EditText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:hint="@string/auth_email"
            android:inputType="textEmailAddress" />

        <EditText
            android:id="@+id/et_password"
            style="@style/Widget.BarcoStop.EditText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:hint="@string/auth_password"
            android:inputType="textPassword" />

        <EditText
            android:id="@+id/et_confirm_password"
            style="@style/Widget.BarcoStop.EditText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:hint="@string/auth_confirm_password"
            android:inputType="textPassword"
            android:visibility="gone" />

        <Button
            android:id="@+id/btn_submit"
            style="@style/Widget.BarcoStop.Button"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="@string/auth_continue" />

        <TextView
            android:id="@+id/tv_auth_or"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="@string/auth_or"
            android:textColor="@color/bs_text_muted"
            android:textSize="12sp"
            android:textStyle="bold" />

        <Button
            android:id="@+id/btn_google_login"
            style="@style/Widget.BarcoStop.Button.Google"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="@string/auth_google_login_prefixed" />

        <Button
            android:id="@+id/btn_toggle_mode"
            style="@style/Widget.BarcoStop.Button.SoftGreen"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="@string/auth_no_account" />

        <ProgressBar
            android:id="@+id/progress"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="16dp"
            android:visibility="gone" />
        </LinearLayout>
    </LinearLayout>
</ScrollView>
