<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_page"
    android:orientation="vertical"
    android:padding="12dp">

    <Button
        android:id="@+id/boats_add_button"
        style="@style/Widget.BarcoStop.Button.Secondary"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/boats_add" />

    <LinearLayout
        android:id="@+id/boats_form"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:background="@drawable/bg_section_card"
        android:orientation="vertical"
        android:padding="12dp"
        android:visibility="gone">

        <EditText
            android:id="@+id/boats_name_input"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/boats_name" />

        <EditText
            android:id="@+id/boats_type_input"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:hint="@string/boats_type" />

        <EditText
            android:id="@+id/boats_capacity_input"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:hint="@string/boats_capacity"
            android:inputType="number" />

        <EditText
            android:id="@+id/boats_safety_input"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:hint="@string/boats_safety"
            android:inputType="textMultiLine"
            android:maxLines="4"
            android:minLines="2" />

        <EditText
            android:id="@+id/boats_description_input"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:hint="@string/boats_description"
            android:inputType="textMultiLine"
            android:maxLines="4"
            android:minLines="2" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:orientation="horizontal">

            <Button
                android:id="@+id/boats_save_button"
                style="@style/Widget.BarcoStop.Button.Secondary"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/boats_save" />

            <Button
                android:id="@+id/boats_cancel_button"
                style="@style/Widget.BarcoStop.Button.Danger"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:layout_weight="1"
                android:text="@string/boats_cancel" />
        </LinearLayout>
    </LinearLayout>

    <ProgressBar
        android:id="@+id/boats_loading"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="10dp" />

    <TextView
        android:id="@+id/boats_empty"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:text="@string/boats_empty"
        android:textColor="@color/bs_text_muted"
        android:visibility="gone" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/boats_recycler"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="8dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:paddingBottom="12dp" />
</LinearLayout>
