<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_page">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="12dp"
        android:background="@drawable/bg_section_card"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Trip type"
            android:textColor="@color/bs_primary_dark"
            android:textStyle="bold" />

        <RadioGroup
            android:id="@+id/create_trip_kind"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:orientation="horizontal">

            <RadioButton
                android:id="@+id/create_kind_trip"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:checked="true"
                android:text="Trip" />

            <RadioButton
                android:id="@+id/create_kind_regatta"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:text="Regatta" />
        </RadioGroup>

        <EditText
            android:id="@+id/create_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:hint="Title" />

        <EditText
            android:id="@+id/create_note"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:gravity="top"
            android:hint="Captain note (optional)"
            android:inputType="textMultiLine"
            android:minLines="3" />

        <EditText
            android:id="@+id/create_boat_image_url"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:hint="Boat image URL (optional)" />

        <EditText
            android:id="@+id/create_origin"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:hint="Origin" />

        <EditText
            android:id="@+id/create_destination"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:hint="Destination" />

        <EditText
            android:id="@+id/create_date"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:hint="Departure date (YYYY-MM-DD)" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="Time window"
            android:textColor="@color/bs_primary_dark"
            android:textStyle="bold" />

        <RadioGroup
            android:id="@+id/create_time_window"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:orientation="horizontal">

            <RadioButton
                android:id="@+id/create_time_morning"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:checked="true"
                android:text="Morning" />

            <RadioButton
                android:id="@+id/create_time_afternoon"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="10dp"
                android:text="Afternoon" />

            <RadioButton
                android:id="@+id/create_time_night"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="10dp"
                android:text="Night" />
        </RadioGroup>

        <EditText
            android:id="@+id/create_seats"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:hint="Available seats"
            android:inputType="number" />

        <EditText
            android:id="@+id/create_price"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:hint="Price (€)"
            android:inputType="numberDecimal" />

        <EditText
            android:id="@+id/create_contribution_type"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:hint="Contribution type (if price = 0)"
            android:visibility="gone" />

        <EditText
            android:id="@+id/create_contribution_note"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:gravity="top"
            android:hint="Contribution note (optional)"
            android:inputType="textMultiLine"
            android:minLines="2"
            android:visibility="gone" />

        <Button
            android:id="@+id/create_submit"
            style="@style/Widget.BarcoStop.Button"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:text="Create trip" />

        <ProgressBar
            android:id="@+id/create_loading"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="14dp"
            android:visibility="gone" />
    </LinearLayout>
</ScrollView>
