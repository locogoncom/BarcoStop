<resources>
    <style name="Widget.BarcoStop.Card" parent="Widget.Material3.CardView.Elevated">
        <item name="cardBackgroundColor">@color/bs_surface</item>
        <item name="cardCornerRadius">16dp</item>
        <item name="cardElevation">1dp</item>
        <item name="strokeColor">@color/bs_border</item>
        <item name="strokeWidth">1dp</item>
    </style>

    <style name="Widget.BarcoStop.Button" parent="Widget.Material3.Button">
        <item name="android:backgroundTint">@color/bs_primary</item>
        <item name="android:textColor">@color/white</item>
        <item name="android:minHeight">48dp</item>
        <item name="cornerRadius">13dp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:paddingStart">14dp</item>
        <item name="android:paddingEnd">14dp</item>
        <item name="android:textAllCaps">false</item>
    </style>

    <style name="Widget.BarcoStop.Button.Secondary" parent="Widget.BarcoStop.Button">
        <item name="android:backgroundTint">@color/bs_secondary</item>
        <item name="android:textColor">@color/white</item>
    </style>

    <style name="Widget.BarcoStop.Button.Outlined" parent="Widget.Material3.Button.OutlinedButton">
        <item name="strokeColor">@color/bs_primary</item>
        <item name="android:textColor">@color/bs_primary_dark</item>
        <item name="cornerRadius">11dp</item>
        <item name="android:minHeight">42dp</item>
        <item name="android:textAllCaps">false</item>
    </style>

    <style name="Widget.BarcoStop.Button.Danger" parent="Widget.BarcoStop.Button">
        <item name="android:backgroundTint">@color/bs_danger</item>
        <item name="android:textColor">@color/white</item>
    </style>

    <style name="Widget.BarcoStop.Button.Compact" parent="Widget.BarcoStop.Button.Secondary">
        <item name="android:minHeight">36dp</item>
        <item name="android:textSize">12sp</item>
        <item name="android:paddingStart">12dp</item>
        <item name="android:paddingEnd">12dp</item>
        <item name="cornerRadius">10dp</item>
    </style>

    <style name="Widget.BarcoStop.Button.Compact.Danger" parent="Widget.BarcoStop.Button.Compact">
        <item name="android:backgroundTint">@color/bs_danger</item>
        <item name="android:textColor">@color/white</item>
    </style>

    <style name="Widget.BarcoStop.Button.Google" parent="Widget.Material3.Button">
        <item name="android:backgroundTint">#BFEFD7</item>
        <item name="android:textColor">#115E3A</item>
        <item name="android:minHeight">48dp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textStyle">bold</item>
        <item name="cornerRadius">12dp</item>
        <item name="android:paddingStart">14dp</item>
        <item name="android:paddingEnd">14dp</item>
    </style>

    <style name="Widget.BarcoStop.Button.SoftGreen" parent="Widget.BarcoStop.Button">
        <item name="android:backgroundTint">#BFEFD7</item>
        <item name="android:textColor">#115E3A</item>
    </style>

    <style name="Widget.BarcoStop.Button.SoftGreen.Compact" parent="Widget.BarcoStop.Button.Compact">
        <item name="android:backgroundTint">#BFEFD7</item>
        <item name="android:textColor">#115E3A</item>
    </style>

    <style name="Widget.BarcoStop.BottomNav.ActiveIndicator" parent="Widget.Material3.BottomNavigationView.ActiveIndicator">
        <item name="android:color">#2238B2A7</item>
    </style>

    <style name="Widget.BarcoStop.EditText" parent="@android:style/Widget.EditText">
        <item name="android:background">@drawable/bg_input</item>
        <item name="android:textColor">@color/bs_text</item>
        <item name="android:textColorHint">@color/bs_text_muted</item>
        <item name="android:padding">12dp</item>
        <item name="android:minHeight">48dp</item>
    </style>

    <style name="Widget.BarcoStop.SearchField" parent="Widget.BarcoStop.EditText">
        <item name="android:minHeight">48dp</item>
        <item name="android:maxLines">1</item>
        <item name="android:imeOptions">actionSearch</item>
        <item name="android:inputType">text</item>
        <item name="android:paddingStart">12dp</item>
        <item name="android:paddingEnd">12dp</item>
        <item name="android:paddingTop">10dp</item>
        <item name="android:paddingBottom">10dp</item>
    </style>

    <style name="Widget.BarcoStop.SearchField.Flat" parent="Widget.BarcoStop.SearchField">
        <item name="android:background">@drawable/bg_input_flat</item>
        <item name="android:paddingStart">10dp</item>
        <item name="android:paddingEnd">10dp</item>
        <item name="android:paddingTop">10dp</item>
        <item name="android:paddingBottom">10dp</item>
    </style>

    <style name="Widget.BarcoStop.SearchField.Borderless" parent="Widget.BarcoStop.SearchField">
        <item name="android:background">@android:color/transparent</item>
        <item name="android:paddingStart">10dp</item>
        <item name="android:paddingEnd">10dp</item>
    </style>


    <style name="ThemeOverlay.BarcoStop.PopupMenu" parent="ThemeOverlay.AppCompat.Light">
        <item name="android:popupBackground">@drawable/bg_popup_menu_soft_green</item>
        <item name="android:textColorPrimary">@color/bs_primary_dark</item>
        <item name="android:textColorSecondary">@color/bs_primary_dark</item>
    </style>

</resources>
