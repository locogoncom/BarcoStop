<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <corners android:radius="12dp" />
            <gradient
                android:angle="315"
                android:startColor="#E6FFFA"
                android:endColor="#CCFBF1" />
            <stroke
                android:width="1dp"
                android:color="@color/bs_border" />
        </shape>
    </item>
    <item
        android:gravity="center"
        android:width="72dp"
        android:height="72dp"
        android:drawable="@drawable/ic_barcostop_logo" />
</layer-list>
