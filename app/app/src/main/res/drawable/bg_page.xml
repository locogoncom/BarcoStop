<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/bs_bg" />
        </shape>
    </item>

    <item android:gravity="top|end">
        <shape android:shape="oval">
            <size android:width="220dp" android:height="220dp" />
            <solid android:color="#35FFFFFF" />
        </shape>
    </item>

    <item android:gravity="bottom|start">
        <shape android:shape="oval">
            <size android:width="260dp" android:height="260dp" />
            <solid android:color="#2D8FE5DB" />
        </shape>
    </item>
</layer-list>
