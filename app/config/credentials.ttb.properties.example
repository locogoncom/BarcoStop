# BarcoStop Native credentials/config template
# Copy to: app/config/credentials.ttb.properties

# Environment
BARCOSTOP_ENV=prod
BARCOSTOP_API_BASE_URL=https://api.barcostop.net/api/v1/
BARCOSTOP_WS_URL=https://api.barcostop.net
BARCOSTOP_BUILD_DATE_UTC=

# Google Login placeholders
GOOGLE_WEB_CLIENT_ID=
GOOGLE_ANDROID_CLIENT_ID=

# Reddit autopost placeholders
REDDIT_CLIENT_ID=
REDDIT_USERNAME=
REDDIT_SUBREDDIT=

# JWT validation hints on client side (optional)
JWT_EXPECTED_ISSUER=
JWT_EXPECTED_AUDIENCE=

# External services
PAYPAL_ME=

# Android release signing
RELEASE_STORE_FILE=
RELEASE_STORE_PASSWORD=
RELEASE_KEY_ALIAS=
RELEASE_KEY_PASSWORD=
