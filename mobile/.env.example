# Optional runtime env hint for Metro process
# Valid values: dev | staging | prod
APP_ENV=dev

# NOTE:
# This project currently resolves APP_ENV from process.env and falls back to:
# - dev when __DEV__ is true
# - prod in release
#
# API URLs are configured in: src/config/apiConfig.ts
# Puedes forzar URL concreta con:
# BARCOSTOP_API_URL=https://api.barcostop.net/v1
