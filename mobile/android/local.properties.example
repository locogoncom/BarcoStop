# Copy this file to `mobile/android/local.properties` and adjust the SDK path.
# Gradle requires `sdk.dir` to point to your Android SDK installation.
#
# Windows example:
# sdk.dir=C:\\Users\\YOUR_USER\\AppData\\Local\\Android\\Sdk
#
# macOS example:
# sdk.dir=/Users/YOUR_USER/Library/Android/sdk
#
# Linux example:
# sdk.dir=/home/your_user/Android/Sdk

sdk.dir=C:\\Users\\YOUR_USER\\AppData\\Local\\Android\\Sdk
