{
  "name": "mobile",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "android": "react-native run-android",
    "android:barcostop": "powershell -ExecutionPolicy Bypass -File ./scripts/run-android-pixel6.ps1",
    "android:activate": "powershell -ExecutionPolicy Bypass -File ./scripts/activate-barcostop.ps1",
    "android:barcostop:linux": "bash ./scripts/run-android-pixel6.sh",
    "android:activate:linux": "bash ./scripts/activate-barcostop.sh",
    "android:start-emulator:linux": "bash ./scripts/start-pixel6.sh",
    "ios": "react-native run-ios",
    "lint": "eslint .",
    "start": "react-native start",
    "test": "jest",
    "postinstall": "patch-package",
    "build:apk:release": "cd android && ./gradlew assembleRelease",
    "build:aab:release": "cd android && ./gradlew bundleRelease"
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "^1.23.1",
    "@react-native/metro-config": "^0.85.2",
    "@react-navigation/bottom-tabs": "^6.6.1",
    "@react-navigation/native": "^6.1.18",
    "@react-navigation/native-stack": "^6.11.0",
    "axios": "^1.13.6",
    "bcrypt": "^6.0.0",
    "patch-package": "^8.0.1",
    "react": "18.2.0",
    "react-native": "0.73.11",
    "react-native-gesture-handler": "2.14.0",
    "react-native-image-picker": "^8.2.1",
    "react-native-qrcode-svg": "^6.2.0",
    "react-native-safe-area-context": "^4.8.0",
    "react-native-screens": "3.27.0",
    "react-native-svg": "14.1.0",
    "react-native-webview": "^13.16.1",
    "socket.io-client": "^4.8.3",
    "text-encoding": "^0.7.0"
  },
  "devDependencies": {
    "@react-native-community/cli": "^12.3.0"
  },
  "engines": {
    "node": ">=18"
  }
}
