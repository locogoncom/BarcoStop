# Server Configuration
PORT=5000
NODE_ENV=production

# Database Type (sqlite or mysql)
DB_TYPE=mysql
DB_HOST=your-database-host.de
DB_PORT=3306
DB_USER=your_user
DB_PASSWORD=your_password
DB_NAME=your_database
SQLITE_PATH=./barcostop.db

# JWT Secret
JWT_SECRET=change_this_to_a_random_secret_key

# CORS
CORS_ORIGIN=*
